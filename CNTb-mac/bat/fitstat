# read the initial parameters of the fit from INFO_F
sub read_INFO_F {
	open (IN,"<$ARGV[0]/INFO_F") || die "cannot open $ARGV[0]/INFO_F";
	chop($p = <IN>);
	chop($min = <IN>);
	chop($max = <IN>);
	close (IN);			
}
