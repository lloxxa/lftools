# read the content of TMP_LOG
sub read_TMP_LOG {
	open(IN,"<$path/TMP_LOG");
	$k = 0;
	while (<IN>) {
		if (/\((.*%)/) { 
			$k++;
			$error[$k] = $1; 
			$error[$k] =~ s/%//;
			s/ //g;
			@tmp = split(/\+\/-/);
			@tmp = split(/=/, $tmp[0]);
			$tl[$k] = $tmp[1];
		}
		if (/correlation matrix of the fit parameters:/) { $corrmat = 1; $j = -3;}
		if ($corrmat) {
			$j++;
			if ($j >= 1) {
				chop($corr[$j] = $_);
				$corr[$j] =~ s/ [ ]*/ /g;
				$corr[$j] =~ s/^[a-c]\d //;
			}
		}
	}
	close(IN);
	$Npeak = $j /3;
	for ($k = 1; $k <= $Npeak; $k++) {
		@corrij = split(/ /,$corr[3*$k]);
		$corr_aw[$k] = $corrij[3*($k - 1)];
	}
}