#!/usr/bin/perl
#######################################
#	Simulate experimental data for CONTIN analysis 
#   Noise picked randomly in the interval [-sigma,+sigma]
#	with sigma = (1+y^2)/4/B/y^2 
#	output 2 columns t, g(2)-1=y^2 for gnuplot
#	Headers and intensity trace are mimicked as in ALV file
#
#   FS last modif 2013/05/30
#######################################

#@t[0]=0;@y[0]=0;@ordinate[0]=0;@abscissa[0]=0;@a[0]=0;@pos[0]=0;@lp[0]=0;
&infos;				# get the parameters for the input distribution
&calc_distr;		# calculate original distribution
&time_base;		# calculate ALV 5000 time base
&calc_y;				# recalculate smoothed data curve from input distribution
&randomize;		# introduce random noise
&output;			# create data file for gnuplot
&plotsim;			# create gnuplot file
`gnuplot plot`;	# run it
 `rm plot`;			# delete it 
&output_asc;		# output ALV-like file

####################################
# get the parameters for the input distribution
sub infos {
	print "Number of log-normal peaks ? (return to skip) ";
	chop($p = <STDIN>);
	if ( $p == "") {	# convenient exit if a similar file exists already
		open(IN,"<distr_param") || die "cannot open distr_param !\n";
		$i=1;
		chop($Ag = <IN>);
		while (<IN>) {
			chop;
			($a[$i], $pos[$i], $lp[$i]) = split(/\t/);
			$i++;
		}
		$p= $#a;
		close(IN);
		
	} else {			# enter parameters manually
		$i = 1;
		print "\nEnter parameters values \n";
		print "Amplitude g1(t) ? ";
		chop($Ag = <STDIN>);
		while ($i <= $p) {
			print "Peak amplitude ",$i," ? ";
			chop($t = <STDIN>);
			$a[$i] = $t;
			print "log [peak position ",$i,"] ? ";
			chop($t = <STDIN>);
			$pos[$i] = $t;
			print "log [peak width ",$i,"] ? ";
			chop($t = <STDIN>);
			$lp[$i] = $t;
			$i++;
		}
		open(OUT,">distr_param")|| die "cannot open distr_param !\n";
		$i=1;
		print OUT $Ag,"\n";
		while ($i <= $p) {
			print OUT $a[$i],"\t", $pos[$i],"\t", $lp[$i],"\n";
			$i++;
		}
		close(OUT);
	}
}
####################################
# calculate original distribution
sub calc_distr {
	$l10=log(10);
	$format="%0.8e";
	
	#	find limits of calculus :
	$i=1; $xmin = $pos[1]; $xmax = $pos[$#pos]; $lmax=0;
	while ($i<=$p) {
		$xmin=($xmin < $pos[$i] ? $xmin : $pos[$i]);
		$xmax=($xmax > $pos[$i] ? $xmax : $pos[$i]);
		$lmax=($lmax > $lp[$i] ? $lmax : $lp[$i]);
		$i++;
	}
	$lmax=10**sqrt(10*$lmax);
	$xmin=10**$xmin/$lmax; $xmax=10**$xmax*$lmax;

	#	calculate distribution :
	$i=1;$x=$xmin;
	while ($x<=$xmax) {
		$j=1;
		while ($j <= $p) {
			$ordinate[$i] = $ordinate[$i] + $a[$j]*exp(-(log($x)/$l10 - $pos[$j])**2/$lp[$j]);
			$j++;
		}
		$abscissa[$i]= $x;
		$x=$x*1.1;
		$i++;
	}
	
	#	normalize distribution / g(1)(t=0)=$Ag :
	$i=1; $cum=0;
	while ($i <= $#ordinate) {
		$cum= $cum + $ordinate[$i];
		$i++;
	}
	$i=1;
	while ($i <= $#ordinate) {
		$ordinate[$i] = $ordinate[$i]/$cum*$Ag;
		$i++;
	}

	#	output distribution	:
	open(OUT, ">distr")|| die "cannot open distr !\n";
	$i=1;
	while ($i <= $#ordinate) {
		print OUT $i,"\t", &format($abscissa[$i]),"\t ", &format($ordinate[$i]),"\n";
		$i++;
	}
	close(OUT);
	
	#	output distribution	normalized to area unity :
	$dtau = (log($abscissa[$#abscissa]) - log($xmin))/$l10/($#abscissa-1);
	open(OUT, ">distr_n")|| die "cannot open distr_n !\n";
	$i=1;
	while ($i <= $#ordinate) {
		print OUT $i,"\t", &format($abscissa[$i]),"\t ", &format($ordinate[$i]/$Ag/$dtau),"\n";
		$i++;
	}		
	close(OUT);
}
####################################
# calculate ALV 5000 time base 
sub time_base {
	$const = 0.4;
	$i = 0;
	while ($i++ < 16) {
		$t[$i] = $i/5e6;
	}
	$j = 0;
	while ($j < 30) {
		$k = 0;
		while ($k++ < 8) {
			$i = 16 + $k + 8*$j;
			$t[$i] = (3.2 + $k * $const) * 2**$j * 1e-6;
		} 
		$j++;
	}
}
####################################
# recalculate smoothed data curve from distribution data
sub calc_y {
	$j = 0; $k = 0;
	while ($j++ < $#t) {
		$i = 0;
		while ($i++ < $#ordinate) {
			$y[$j] += $ordinate[$i] * exp( -$t[$j] / $abscissa[$i] );
		}
		if ( $y[$j] >= 2*$y[1]/(4*$ARGV[1])**(1/3) ) { $k++;}
	}
#	print "ylim= ",$y[1]/(4*$ARGV[1])**(1/3)," #t= ",$#t,", #y= ",$k,"\n";	
}
####################################
# introduce random noise
sub randomize {
	$i = 1;
	srand(1);
	$b = $ARGV[1];
	print "B= ",$b,"\n";
	while ($i <= $k) {
		$sigma=(1 + $y[$i]**2)/4/$b/$y[$i]**2;
#		print "# ",$i,"  y= ",$y[$i]," sig= ",$sigma,"\n";
#		$sigma=($sigma < $y[$i] ? $sigma : $y[$i]);
		$y[$i] = ($y[$i] + $sigma*2*(rand(1)-.5))**2;
		$i++;
	}
	while ($i <= $#t) {
		$temp = $y[$i] + $sigma*2*(rand(1)-.5)*($t[$k]/$t[$i])**(0.25);
		$y[$i] = ($temp > 0 ? $temp**2 : - $temp**2);
		$i++;
	}	
}
####################################
# file for gnuplot
sub output {		
	open(OUT, ">$ARGV[0]") || die "cannot open file $ARGV[0] for output !\n";
	$i = 1;
#	while ($i <= $k) {
	while ($i <= $#t) {
		$t[$i] =~ s/e/E/;
		$y[$i] =~ s/e/E/;
		print OUT "  ", $t[$i],"\t  ", $y[$i],"\n";
		$i++;
	}
	close(OUT);
}
