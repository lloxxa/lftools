####################################
# translate number to a FORTRAN form (-).xxxE+xx
sub format {
	$f=10*shift(@_);
	$form = sprintf $format, abs($f);
	$form =~ s/\.//;
	$form =~ s/e/E/;
	if ($f >= 0) {
		$form= ".".$form;
	} else {
		@interm=split(E,$form);
		chop($interm[0]);	
		$form="-.".join(E,@interm);
	}
	$form;
}
####################################
# create gnuplot file to display simulated data with noise
sub plotsim {
	open(OUT,">plot") || die "cannot open plot for output";
	print OUT qq(set termoption enhanced\n);
	print OUT qq(set sample 512\n);
	print OUT qq(set logscale x\n);
	print OUT qq(set xtics 10 format "10^{%T}" nomirror\n);
	print OUT qq(unset mxtics\n);
	print OUT qq(set logscale y\n);
	print OUT qq(set ytics 10 format "10^{%T}" nomirror\n);
	print OUT qq(unset mytics\n);
	print OUT qq(set xrange [1e-7:1e2]\n);
	print OUT qq(set yrange [1e-5:1]\n);
	print OUT qq(set xlabel "t (s)" font "Helvetica,24"\n);
	print OUT qq(set ylabel "Y(t)" font "Helvetica,24" offset 0,0\n);
	print OUT qq(plot "$ARGV[0]" using 1:2 pt 7 ps 1.5\n);
	print OUT qq(pause mouse any\n);
	close OUT;
}

